{
    "rewrites": [
        {
            "source": "/validation-key.txt",
            "destination": "/validation-key.txt"
        },
        {
            "source": "/api/(.*)",
            "destination": "/api"
        },
        {
            "source": "/((?!api/).*)",
            "destination": "/index.html"
        }
    ],
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "X-Frame-Options",
                    "value": "ALLOWALL"
                },
                {
                    "key": "Content-Security-Policy",
                    "value": "frame-ancestors *"
                }
            ]
        }
    ],
    "functions": {
        "api/**/*.ts": {
            "maxDuration": 30
        }
    }
}